{
  "name": "shallweswim-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "export-openapi": "uv --directory .. run python -m shallweswim.scripts.export_openapi > openapi.json",
    "generate-api": "openapi-typescript ./openapi.json -o ./src/api/generated.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:smoke": "playwright test --grep @smoke --project=mobile-chromium",
    "test:e2e": "playwright test --grep-invert @smoke --project=mobile-chromium && playwright test --grep @desktop --project=desktop-chromium",
    "check:api": "corepack pnpm@10.18.3 export-openapi && corepack pnpm@10.18.3 generate-api && git diff --exit-code openapi.json src/api/generated.ts"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "2.1.2",
      "js-yaml": "4.3.0",
      "ws": "8.21.0"
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.0",
    "openapi-fetch": "^0.15.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-feather": "^2.0.10",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@playwright/test": "1.59.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "0.28.1",
    "jsdom": "^27.4.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  }
}
